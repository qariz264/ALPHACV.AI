rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Resumes Collection
    match /resumes/{resumeId} {
      // Allow users to list and get their own resumes only
      allow read: if isSignedIn() && existing().userId == request.auth.uid;

      // Allow creating a resume associated with the current user's uid
      allow create: if isSignedIn()
        && isValidId(resumeId)
        && incoming().userId == request.auth.uid
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().fullName is string && incoming().fullName.size() <= 200
        && incoming().hasPaid is bool
        && incoming().createdAt is string && incoming().createdAt.size() <= 40
        && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;

      // Allow updating owned resumes while protecting user ownership and creation timestamp boundaries
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().fullName is string && incoming().fullName.size() <= 200
        && incoming().hasPaid is bool
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt is string && incoming().updatedAt.size() <= 40;

      // Allow deleting owned resumes
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(paymentId)
        && incoming().userId == request.auth.uid
        && incoming().resumeId is string
        && incoming().reference is string
        && incoming().amount is number
        && incoming().status is string
        && incoming().createdAt is string && incoming().createdAt.size() <= 40;

      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().status is string
        && incoming().createdAt == existing().createdAt;
    }
  }
}
